<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HabitPulse" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Fallback colorPrimary for pre-Monet devices; dynamic colors will override on Android 12+ -->
        <item name="colorPrimary">@color/purple_200</item>
        <!-- Transparent status and navigation bar to prevent purple flash on startup -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Prefer light icons on dark theme -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash theme used as application's launch theme so the system shows a proper background -->
    <style name="Theme.HabitPulse.Splash" parent="Theme.SplashScreen">
        <!-- Use explicit color for night mode -->
        <item name="windowSplashScreenBackground">@color/black</item>
        <!-- Keep status bar transparent during splash -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Keep the app theme after the splash finishes -->
        <item name="postSplashScreenTheme">@style/Theme.HabitPulse</item>
    </style>

</resources>
